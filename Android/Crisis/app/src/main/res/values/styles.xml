<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="apple">
        <item name="cornerSizeBottomLeft">120sp</item>
        <item name="cornerSizeBottomRight">120sp</item>
    </style>

    <style name="inputLayoutPoint">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="cardBackgroundColor">@color/colorPoint</item>
        <item name="cardCornerRadius">10sp</item>
        <item name="cardElevation">5sp</item>
        <item name="cardUseCompatPadding">true</item>
    </style>

    <style name="editPoint">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">50sp</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:padding">10sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="btn">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">12dp</item>
        <item name="android:background">@drawable/curve</item>
        <item name="android:backgroundTint">@color/colorPoint</item>
    </style>

    <style name="spinnerStyle">
        <item name="colorPrimary">@color/black</item>
        <item name="background">@drawable/curve</item>
    </style>
</resources>