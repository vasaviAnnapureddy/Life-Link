<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E9000000"
        android:scaleType="center"
        android:paddingTop="90dp"
        android:src="@drawable/ngo"
        android:tintMode="src_atop"
        app:tint="#CF000000" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="250sp"
        android:forceHasOverlappingRendering="true"
        app:cardBackgroundColor="@color/colorPoint"
        app:cardElevation="0sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        app:shapeAppearance="@style/apple"
        tools:ignore="UnusedAttribute">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|start">

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10sp"
                app:cardCornerRadius="50sp"
                app:cardElevation="10sp">

                <ImageView
                    android:layout_width="50sp"
                    android:layout_height="50sp"
                    android:src="@drawable/user_2" />

            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/userWish2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="10sp"
                android:text="Hi Ngo" />
        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>
    <androidx.cardview.widget.CardView
        android:id="@+id/cardPointView2"
        android:layout_width="300sp"
        android:layout_height="150sp"
        app:cardCornerRadius="10sp"
        app:cardUseCompatPadding="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.3">

        <com.db.williamchart.view.BarChartView
            android:id="@+id/cartesian2"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20sp"
            app:chart_axis="x"
            app:chart_barsColor="@color/colorPoint"
            app:chart_barsRadius="10sp"
            app:chart_labelsColor="@color/colorPoint"
            app:chart_labelsSize="12sp" />

    </androidx.cardview.widget.CardView>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/cycle3"
        android:layout_width="0sp"
        android:layout_height="0sp"

        android:foregroundGravity="center"
        android:paddingTop="300sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        tools:listitem="@layout/card_point" />


</androidx.constraintlayout.widget.ConstraintLayout>